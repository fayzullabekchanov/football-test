# .env.local - bu faylni loyiha papkasiga qo'ying
# Vercelda bu qiymatlarni Environment Variables bo'limiga kiriting

# Neon PostgreSQL dan olingan connection string
DATABASE_URL="postgresql://username:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Ixtiyoriy, masalan: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-key-here"

# Vercelda deploy bo'lganda o'zgartiring
NEXTAUTH_URL="http://localhost:3000"
